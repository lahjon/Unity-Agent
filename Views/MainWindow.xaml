<Window x:Class="Spritely.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Spritely"
        xmlns:controls="clr-namespace:Spritely.Controls"
        Title="Spritely" Width="1280" Height="820"
        Background="{StaticResource BgDeep}" WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Controls/Templates/TaskCardTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid x:Name="RootGrid" Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="120"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="60"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition x:Name="TerminalRow" Height="Auto" MinHeight="0"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="LeftPanelCol" Width="285" MinWidth="150"/>
            <ColumnDefinition x:Name="LeftSplitterCol" Width="Auto"/>
            <ColumnDefinition Width="*" MinWidth="220"/>
            <ColumnDefinition x:Name="ChatSplitterCol" Width="0"/>
            <ColumnDefinition x:Name="ChatPanelCol" Width="0" MinWidth="0"/>
            <ColumnDefinition x:Name="RightSplitterCol" Width="Auto"/>
            <ColumnDefinition x:Name="RightPanelCol" Width="285" MinWidth="150"/>
        </Grid.ColumnDefinitions>

        <!-- Collapsed strip for left panel (shown when left panel is collapsed). Lives in the left splitter column. -->
        <Border x:Name="LeftPanelCollapsedStrip" Grid.Row="0" Grid.Column="1" Grid.RowSpan="3"
                Background="{StaticResource BgSurface}" CornerRadius="8" Padding="0" Visibility="Collapsed"
                BorderThickness="1" BorderBrush="{StaticResource BgElevated}" Width="32"
                Margin="0,0,3,0">
            <Button x:Name="ExpandLeftPanelBtn" Click="ToggleLeftPanel_Click"
                    ToolTip="Expand Left Panel" VerticalAlignment="Top" HorizontalAlignment="Center"
                    Margin="0,6,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource IconBtn}">
                        <Setter Property="Content" Value="&#xE76C;"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                    </Style>
                </Button.Style>
            </Button>
        </Border>

        <!-- Projects panel removed – content moved to Projects tab in right panel -->

        <!-- Vertical Splitter: Left ↔ Center/Right -->
        <GridSplitter x:Name="LeftSplitter" Grid.Column="1" Grid.RowSpan="5" Style="{StaticResource VerticalSplitter}"/>

        <!-- ═══ PROMPTS (2) ═══ -->
        <Border Grid.Row="2" Grid.Column="2" Background="{StaticResource BgSurface}" CornerRadius="8" Padding="10"
                BorderThickness="1">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="InputSectionBorder" Color="#2C2C2C"/>
                </Border.BorderBrush>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="InputSectionBorder"
                                                Storyboard.TargetProperty="Color"
                                                To="#3A3A3A" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="InputSectionBorder"
                                                Storyboard.TargetProperty="Color"
                                                To="#2C2C2C" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Grid>
                <DockPanel>
                    <!-- Top: Saved Prompts strip (above prompt so panel can collapse further) -->
                    <Border x:Name="SavedPromptsBorder" DockPanel.Dock="Top"
                            Background="{StaticResource BgSurface}" CornerRadius="4"
                            BorderBrush="{StaticResource BgElevated}" BorderThickness="1"
                            Margin="0,0,0,6" Padding="6,4">
                        <DockPanel>
                            <Button DockPanel.Dock="Left" Click="SavedPromptsToggle_Click"
                                    Style="{StaticResource GhostBtn}"
                                    Padding="0" Margin="0,0,6,0" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SavedPromptsArrow" Text="&#x25BE;" Foreground="{StaticResource Accent}"
                                               FontSize="11" FontWeight="Bold" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="SAVED" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                               FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <ScrollViewer x:Name="SavedPromptsScrollViewer" VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollBarVisibility="Auto" MaxHeight="62">
                                <ItemsControl x:Name="SavedPromptsPanel"
                                              ItemTemplate="{StaticResource SavedPromptTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Top: Skills strip -->
                    <Border x:Name="SkillsBorder" DockPanel.Dock="Top"
                            Background="{StaticResource BgSurface}" CornerRadius="4"
                            BorderBrush="{StaticResource BgElevated}" BorderThickness="1"
                            Margin="0,0,0,6" Padding="6,4">
                        <DockPanel>
                            <Button DockPanel.Dock="Left" Click="SkillsToggle_Click"
                                    Style="{StaticResource GhostBtn}"
                                    Padding="0" Margin="0,0,6,0" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="SkillsArrow" Text="&#x25BE;" Foreground="#E8A86C"
                                               FontSize="11" FontWeight="Bold" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="SKILLS" Foreground="#E8A86C" FontWeight="Bold"
                                               FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button DockPanel.Dock="Right" Content="Manage" Click="ManageSkills_Click"
                                    Style="{StaticResource GhostBtn}"
                                    Foreground="{StaticResource TextMuted}" FontSize="10"
                                    FontFamily="Segoe UI" Padding="6,2" VerticalAlignment="Top"
                                    ToolTip="Create, edit, and delete skills"/>
                            <ScrollViewer x:Name="SkillsScrollViewer" VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollBarVisibility="Auto" MaxHeight="62">
                                <WrapPanel x:Name="SkillsPanel" Orientation="Horizontal"/>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Top: Advanced toggles strip -->
                    <Border x:Name="AdvancedBorder" DockPanel.Dock="Top"
                            Background="{StaticResource BgSurface}" CornerRadius="4"
                            BorderBrush="{StaticResource BgElevated}" BorderThickness="1"
                            Margin="0,0,0,6" Padding="6,4"
                            Visibility="Collapsed">
                        <DockPanel>
                            <Button DockPanel.Dock="Left" Click="AdvancedToggle_Click"
                                    Style="{StaticResource GhostBtn}"
                                    Padding="0" Margin="0,0,6,0" VerticalAlignment="Top">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="AdvancedArrow" Text="&#x25BE;" Foreground="{StaticResource Accent}"
                                               FontSize="11" FontWeight="Bold" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="ADVANCED" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                               FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <ScrollViewer x:Name="AdvancedScrollViewer" VerticalScrollBarVisibility="Disabled"
                                          HorizontalScrollBarVisibility="Auto" MaxHeight="62">
                                <WrapPanel Orientation="Horizontal">
                                    <ToggleButton x:Name="IgnoreFileLocksToggle" IsChecked="False"
                                                  Style="{StaticResource ToggleChip}" ToolTip="Ignore file locks when launching tasks">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE785;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Foreground="{StaticResource TextLight}"/>
                                            <TextBlock Text="Ignore Locks" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="UseMcpToggle" IsChecked="False"
                                                  Style="{StaticResource ToggleChip}" ToolTip="Use MCP connection">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Foreground="{StaticResource TextLight}"/>
                                            <TextBlock Text="MCP" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                            <Ellipse x:Name="McpHealthIndicator" Width="6" Height="6" Fill="{StaticResource TextMuted}" Margin="4,0,0,0" VerticalAlignment="Center"
                                                     ToolTip="MCP connection status"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="AutoVerifyToggle" IsChecked="False"
                                                  Style="{StaticResource ToggleChip}" ToolTip="Automatically verify task output"
                                                  Checked="AutoVerifyToggle_Changed" Unchecked="AutoVerifyToggle_Changed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Foreground="{StaticResource TextLight}"/>
                                            <TextBlock Text="Auto-Verify" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="ApplyFixToggle" IsChecked="True"
                                                  Style="{StaticResource ToggleChip}" ToolTip="Apply fixes directly"
                                                  Checked="ApplyFixToggle_Changed" Unchecked="ApplyFixToggle_Changed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Foreground="{StaticResource TextLight}"/>
                                            <TextBlock Text="Apply Fix" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="SpawnTeamToggle" IsChecked="False"
                                                  Style="{StaticResource ToggleChip}" Visibility="Collapsed" ToolTip="Spawn team for task">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Foreground="{StaticResource TextLight}"/>
                                            <TextBlock Text="Team" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="TeamsModeToggle" IsChecked="False"
                                                  Style="{StaticResource ToggleChip}" ToolTip="Enable teams mode with iterations"
                                                  Checked="TeamsModeToggle_Changed" Unchecked="TeamsModeToggle_Changed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Foreground="{StaticResource TextLight}"/>
                                            <TextBlock Text="Teams" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <StackPanel x:Name="TeamsModeIterationsPanel" Orientation="Horizontal" Margin="0,0,4,4" Visibility="Collapsed">
                                        <TextBlock Text="×" Foreground="{StaticResource TextMuted}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,2,0"/>
                                        <TextBox x:Name="TeamsModeIterationsBox" Text="2" Width="36" FontSize="10" FontFamily="Segoe UI"
                                                 Background="{StaticResource BgDeep}" Foreground="{StaticResource TextPrimary}"
                                                 CaretBrush="{StaticResource TextPrimary}" BorderBrush="{StaticResource BorderSubtle}"
                                                 BorderThickness="1" Padding="4,2" VerticalContentAlignment="Center"
                                                 PreviewTextInput="IterationsBox_PreviewTextInput"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ExtendedPlanningToggle" IsChecked="False"
                                                  Style="{StaticResource ToggleChip}" ToolTip="Use extended planning phase">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Foreground="{StaticResource TextLight}"/>
                                            <TextBlock Text="Ext. Plan" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="PlanOnlyToggle" IsChecked="False"
                                                  Style="{StaticResource ToggleChip}" ToolTip="Generate plan without executing"
                                                  Checked="PlanOnlyToggle_Changed" Unchecked="PlanOnlyToggle_Changed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Foreground="{StaticResource TextLight}"/>
                                            <TextBlock Text="Plan Only" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="AutoDecomposeToggle" IsChecked="False"
                                                  Style="{StaticResource ToggleChip}" ToolTip="Auto-decompose into subtasks">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8AB;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Foreground="{StaticResource TextLight}"/>
                                            <TextBlock Text="Decompose" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                    <ToggleButton x:Name="AutoQueueToggle" IsChecked="False"
                                                  Style="{StaticResource ToggleChip}" ToolTip="New tasks depend on the previously created task, forming a linear queue"
                                                  Checked="AutoQueueToggle_Changed" Unchecked="AutoQueueToggle_Changed">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="&#xE8CB;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                                       Foreground="{StaticResource TextLight}"/>
                                            <TextBlock Text="Auto-Queue" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </ToggleButton>
                                </WrapPanel>
                            </ScrollViewer>
                        </DockPanel>
                    </Border>

                    <!-- Prompt input area -->
                <DockPanel>
                    <!-- Top: Prompt label, model selector, text input -->
                    <DockPanel>
                        <!-- Panel label + Model selector -->
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                            <TextBlock Text="PROMPT" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                       FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                            <ComboBox x:Name="PromptProjectLabel" Foreground="{StaticResource TextPrimary}" FontFamily="Segoe UI"
                                      FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"
                                      MaxWidth="180" MinWidth="60" Background="Transparent"
                                      BorderThickness="0" Cursor="Hand"/>
                            <!-- Model combo (hidden, used by code) -->
                            <ComboBox x:Name="ModelCombo" SelectedIndex="0" Visibility="Collapsed"
                                      SelectionChanged="ModelCombo_Changed">
                                <ComboBoxItem Content="Claude Code" Tag="ClaudeCode"/>
                                <ComboBoxItem Content="Gemini (Image Gen)" Tag="Gemini"/>
                                <ComboBoxItem Content="Gemini (Game Art)" Tag="GeminiGameArt"/>
                            </ComboBox>
                            <ComboBox x:Name="AssetTypeCombo" SelectedIndex="0" Visibility="Collapsed">
                                <ComboBoxItem Content="Sprite" Tag="Sprite"/>
                                <ComboBoxItem Content="Texture" Tag="Texture"/>
                                <ComboBoxItem Content="UI Icon" Tag="UIIcon"/>
                                <ComboBoxItem Content="Tilemap" Tag="Tilemap"/>
                            </ComboBox>
                            <TextBlock x:Name="AssetTypeLabel" Visibility="Collapsed"/>
                            <TextBlock Text="TEMPLATE" Foreground="{StaticResource TextMuted}" FontWeight="Bold"
                                       FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"
                                       Margin="20,0,6,0"/>
                            <ComboBox x:Name="TemplateCombo"
                                      FontSize="11" Padding="6,3" MinWidth="170"
                                      HorizontalAlignment="Left"
                                      SelectionChanged="TemplateCombo_Changed">
                                <ComboBoxItem Content="(No Template)" Tag=""/>
                            </ComboBox>
                            <Button Content="Save Template" Click="SaveAsTemplate_Click"
                                    Style="{StaticResource GhostBtn}" Foreground="{StaticResource TextMuted}"
                                    FontSize="9" FontFamily="Segoe UI" Padding="6,2"
                                    VerticalAlignment="Center" Margin="8,0,0,0"
                                    ToolTip="Save current toggle states as a reusable template"/>
                            <ToggleButton x:Name="AutoModeToggle" IsChecked="True"
                                          Style="{StaticResource ToggleChip}" VerticalAlignment="Center" Margin="12,0,0,0"
                                          ToolTip="Enable preprocessor and hide advanced toggles"
                                          Checked="AutoModeToggle_Changed" Unchecked="AutoModeToggle_Changed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE945;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                               Foreground="{StaticResource TextLight}"/>
                                    <TextBlock Text="Auto-Mode" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                            <ToggleButton x:Name="AutoTeamsModeToggle" IsChecked="True"
                                          Style="{StaticResource ToggleChip}" VerticalAlignment="Center" Margin="4,0,0,0"
                                          ToolTip="Allow preprocessor to infer feature mode for task decomposition"
                                          Checked="AutoTeamsModeToggle_Changed" Unchecked="AutoTeamsModeToggle_Changed">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE734;" FontFamily="Segoe MDL2 Assets" FontSize="10" VerticalAlignment="Center" Margin="0,0,4,0"
                                               Foreground="{StaticResource TextLight}"/>
                                    <TextBlock Text="Feature-Mode" Foreground="{StaticResource TextLight}" FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </StackPanel>
                            </ToggleButton>
                            <Button Content="Clear" Click="ClearPrompt_Click"
                                    Style="{StaticResource GhostBtn}" Foreground="{StaticResource TextMuted}"
                                    FontSize="10" FontFamily="Segoe UI" Padding="6,2"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"
                                    ToolTip="Clear prompt text"/>
                        </DockPanel>
                        <!-- Active project name removed from here; shown next to Execute button -->
                        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,3,0,0">
                            <TextBlock x:Name="ImageIndicator" Foreground="{StaticResource Accent}" FontSize="11"
                                       FontFamily="Segoe UI" VerticalAlignment="Center" Visibility="Collapsed"/>
                            <Button x:Name="ClearImagesBtn" Content="Clear" Click="ClearImages_Click"
                                    Style="{StaticResource GhostBtn}" Foreground="{StaticResource Danger}"
                                    Margin="6,0,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                        <!-- Additional instructions (saved with templates) - collapsible -->
                        <DockPanel DockPanel.Dock="Top" Margin="0,3,0,0">
                            <ToggleButton x:Name="AdditionalInstructionsToggle" DockPanel.Dock="Top"
                                          IsChecked="False" Cursor="Hand"
                                          Click="AdditionalInstructionsToggle_Click"
                                          Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Left"
                                          Padding="0" Margin="0,0,0,2">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock x:Name="CollapseChevron" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="8"
                                                           Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" Margin="0,0,4,0"
                                                           RenderTransformOrigin="0.5,0.5">
                                                    <TextBlock.RenderTransform>
                                                        <RotateTransform Angle="-90"/>
                                                    </TextBlock.RenderTransform>
                                                </TextBlock>
                                                <TextBlock Text="ADDITIONAL INSTRUCTIONS" Foreground="{StaticResource TextMuted}"
                                                           FontWeight="Bold" FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <TextBox x:Name="AdditionalInstructionsInput" AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="36" MaxHeight="100"
                                     Visibility="Collapsed"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="{StaticResource BgDeep}" Foreground="{StaticResource TextPrimary}"
                                     CaretBrush="{StaticResource TextPrimary}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                     FontSize="12" FontFamily="Consolas" Padding="6"
                                     ToolTip="Additional instructions saved with templates (e.g. coding standards, constraints)"/>
                        </DockPanel>
                        <!-- Dependency drop zone -->
                        <Border x:Name="DependencyDropZone" DockPanel.Dock="Top"
                                Background="#1A1A1A" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                CornerRadius="4" MinHeight="28" Margin="0,3,0,0" Padding="6,4"
                                AllowDrop="True"
                                PreviewDragOver="DependencyZone_DragOver"
                                Drop="DependencyZone_Drop">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Left" Text="DEPS" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                           FontSize="9" FontFamily="Segoe UI" VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <TextBlock x:Name="DependencyPlaceholder" Text="Drag tasks here to add dependencies..."
                                           Foreground="{StaticResource TextDisabled}" FontSize="11" FontFamily="Segoe UI"
                                           VerticalAlignment="Center"/>
                                <ItemsControl x:Name="DependencyChips" Visibility="Collapsed">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </DockPanel>
                        </Border>
                        <!-- Divider between deps and prompt -->
                        <Border DockPanel.Dock="Top" Margin="0,3,0,3" Height="1"
                                Background="{StaticResource BorderSubtle}" Opacity="0.4"/>
                        <!-- Prompt input + action buttons -->
                        <DockPanel>
                            <!-- Right: Action buttons beside prompt input -->
                            <StackPanel DockPanel.Dock="Right" Margin="6,0,0,0" VerticalAlignment="Center">
                                <Button Content="&#xE7B8;" Click="StoreTask_Click"
                                        Style="{StaticResource PromptActionBtn}"
                                        ToolTip="Store Task"
                                        Margin="0,0,0,4"/>
                                <Button Content="&#xE74E;" Click="SavePromptEntry_Click"
                                        Style="{StaticResource PromptActionBtn}"
                                        ToolTip="Save Prompt"
                                        Margin="0,0,0,4"/>
                                <Button Content="&#xE8F1;" Click="ComposeWorkflow_Click"
                                        Style="{StaticResource PromptActionBtn}"
                                        ToolTip="Compose Workflow"
                                        Margin="0,0,0,4"/>
                                <Button x:Name="ExecuteButton" Content="&#xE768;" Click="Execute_Click"
                                        Style="{StaticResource PromptActionBtn}"
                                        Background="{StaticResource Accent}" Foreground="White"
                                        ToolTip="Execute Task"/>
                            </StackPanel>
                            <TextBox x:Name="TaskInput" AcceptsReturn="True" TextWrapping="Wrap"
                                     MinHeight="80"
                                     VerticalScrollBarVisibility="Auto"
                                     Background="{StaticResource BgDeep}" Foreground="{StaticResource TextPrimary}"
                                     CaretBrush="{StaticResource TextPrimary}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                     FontSize="13" FontFamily="Consolas" Padding="6"
                                     PreviewKeyDown="TaskInput_PreviewKeyDown"
                                     TextChanged="TaskInput_TextChanged"
                                     AllowDrop="True" PreviewDragOver="TaskInput_DragOver"
                                     Drop="TaskInput_Drop"/>
                        </DockPanel>
                    </DockPanel>
                </DockPanel>


                </DockPanel>
                <!-- No-project overlay: shown when no projects are loaded -->
                <Border x:Name="NoProjectOverlay" Visibility="Collapsed"
                        Background="#CC1A1A1A" CornerRadius="6">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                   Foreground="{StaticResource TextDisabled}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="No Project Selected" Foreground="{StaticResource TextLight}"
                                   FontSize="18" FontWeight="SemiBold" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="Add a project from the Projects tab to get started."
                                   Foreground="{StaticResource TextMuted}" FontSize="12" FontFamily="Segoe UI"
                                   HorizontalAlignment="Center" TextWrapping="Wrap" MaxWidth="320"/>
                    </StackPanel>
                </Border>
                </Grid>
            </Border>

        <!-- Horizontal Splitter: Top ↔ Middle (Thumb-based to avoid GridSplitter star-sizing jitter) -->
        <Thumb x:Name="TopMiddleSplitter" Grid.Row="1" Grid.ColumnSpan="7"
               Style="{StaticResource HorizontalSplitterThumb}"
               DragStarted="TopMiddleSplitter_DragStarted"
               DragDelta="TopMiddleSplitter_DragDelta"
               DragCompleted="TopMiddleSplitter_DragCompleted"/>

        <!-- ═══ TASK LIST (3) ═══ -->
        <Border x:Name="TaskListPanelBorder" Grid.Row="0" Grid.Column="0" Grid.RowSpan="5" Background="{StaticResource BgSurface}" CornerRadius="8" Padding="10"
                BorderThickness="1" ClipToBounds="True">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="SidebarBorder" Color="#2C2C2C"/>
                </Border.BorderBrush>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="SidebarBorder"
                                                Storyboard.TargetProperty="Color"
                                                To="#3A3A3A" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="SidebarBorder"
                                                Storyboard.TargetProperty="Color"
                                                To="#2C2C2C" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition x:Name="TaskListRow" Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="4,2,4,6">
                        <TextBlock Text="TASK LIST" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                   FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <Button Click="ToggleLeftPanel_Click" ToolTip="Collapse Left Panel"
                                HorizontalAlignment="Right" DockPanel.Dock="Right">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconBtn}">
                                    <Setter Property="Content" Value="&#xE76B;"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                </Style>
                            </Button.Style>
                        </Button>
                    </DockPanel>
                <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0"
                           SelectionChanged="TaskListTab_SelectionChanged">
                    <TabItem>
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="ACTIVE" FontWeight="Bold" FontSize="11" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="ActiveTabCount" FontWeight="Bold" FontSize="11"
                                           FontFamily="Segoe UI" Foreground="{StaticResource TextSubdued}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="4,0,0,8">
                                <Button Content="Clear" Click="ClearFinished_Click"
                                        Style="{StaticResource GhostBtn}" DockPanel.Dock="Right"/>
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="ActiveFilterCombo" SelectionChanged="ActiveFilter_Changed"
                                              FontSize="10" Padding="6,3"
                                              HorizontalAlignment="Left"/>
                                    <ComboBox x:Name="ActiveStatusFilterCombo" SelectionChanged="ActiveStatusFilter_Changed"
                                              FontSize="10" Padding="6,3" Margin="4,0,0,0"
                                              HorizontalAlignment="Left"/>
                                </StackPanel>
                            </DockPanel>
                            <Grid Grid.Row="1" Margin="4,0,4,6">
                                <TextBox x:Name="ActiveSearchBox"
                                         FontSize="12" Padding="6,4"
                                         Background="{StaticResource BgElevated}"
                                         Foreground="{StaticResource TextPrimary}"
                                         BorderThickness="1"
                                         TextChanged="ActiveSearchBox_TextChanged"/>
                                <TextBlock Text="Search tasks..." IsHitTestVisible="False"
                                           FontSize="12" Padding="8,5"
                                           Foreground="{StaticResource TextSubdued}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=ActiveSearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <ListBox x:Name="ActiveTasksList" Grid.Row="2"
                                     Style="{StaticResource TaskListStyle}"
                                     ItemTemplate="{StaticResource ActiveTaskTemplate}"
                                     SelectionChanged="ActiveTask_Selected"
                                     MouseDoubleClick="ActiveTaskList_MouseDoubleClick"
                                     PreviewMouseWheel="TaskList_PreviewMouseWheel"
                                     AllowDrop="True"
                                     PreviewMouseLeftButtonDown="ActiveTasksList_PreviewMouseLeftButtonDown"
                                     PreviewMouseMove="ActiveTasksList_PreviewMouseMove"
                                     DragOver="ActiveTasksList_DragOver"
                                     Drop="ActiveTasksList_Drop"/>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="HistoryTabItem">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="HISTORY" FontWeight="Bold" FontSize="11" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="HistoryTabCount" FontWeight="Bold" FontSize="11"
                                           FontFamily="Segoe UI" Foreground="{StaticResource TextSubdued}"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="4,0,0,8">
                                <Button Content="Clear" Click="ClearHistory_Click"
                                        Style="{StaticResource GhostBtn}" DockPanel.Dock="Right"/>
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="HistoryFilterCombo" SelectionChanged="HistoryFilter_Changed"
                                              FontSize="10" Padding="6,3" Margin="0,0,4,0"
                                              HorizontalAlignment="Left"/>
                                    <ComboBox x:Name="HistoryStatusFilterCombo" SelectionChanged="HistoryStatusFilter_Changed"
                                              FontSize="10" Padding="6,3" Margin="0,0,4,0"
                                              HorizontalAlignment="Left"/>
                                </StackPanel>
                            </DockPanel>
                            <Grid Grid.Row="1" Margin="4,0,4,6">
                                <TextBox x:Name="HistorySearchBox"
                                         FontSize="12" Padding="6,4"
                                         Background="{StaticResource BgElevated}"
                                         Foreground="{StaticResource TextPrimary}"
                                         BorderThickness="1"
                                         TextChanged="HistorySearchBox_TextChanged"/>
                                <TextBlock Text="Search tasks..." IsHitTestVisible="False"
                                           FontSize="12" Padding="8,5"
                                           Foreground="{StaticResource TextSubdued}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=HistorySearchBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <ListBox x:Name="HistoryTasksList" Grid.Row="2"
                                     Style="{StaticResource TaskListStyle}"
                                     ItemTemplate="{StaticResource HistoryTaskTemplate}"
                                     SelectionMode="Extended"
                                     SelectionChanged="HistoryTask_Selected"
                                     PreviewMouseWheel="TaskList_PreviewMouseWheel"/>
                        </Grid>
                    </TabItem>
                    <TabItem x:Name="StoredTabItem">
                        <TabItem.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="STORED" FontWeight="Bold" FontSize="11" FontFamily="Segoe UI"/>
                                <TextBlock x:Name="StoredTabBadge" FontWeight="Bold" FontSize="11"
                                           FontFamily="Segoe UI" Foreground="{StaticResource TextSubdued}" Visibility="Collapsed"/>
                            </StackPanel>
                        </TabItem.Header>
                        <Grid Margin="0,6,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="4,0,0,8">
                                <Button Content="Clear" Click="ClearStoredTasks_Click"
                                        Style="{StaticResource GhostBtn}" DockPanel.Dock="Right"/>
                                <ComboBox x:Name="StoredFilterCombo" SelectionChanged="StoredFilter_Changed"
                                          FontSize="10" Padding="6,3"
                                          HorizontalAlignment="Left"/>
                            </DockPanel>
                            <ListBox x:Name="StoredTasksList" Grid.Row="1"
                                     Style="{StaticResource TaskListStyle}"
                                     ItemTemplate="{StaticResource StoredTaskTemplate}"
                                     PreviewMouseWheel="TaskList_PreviewMouseWheel"/>
                        </Grid>
                    </TabItem>
                </TabControl>
                </Grid>
            </Border>

        <!-- ═══ GRAPH + TASK OUTPUT (4) ═══ -->
        <Grid Grid.Row="0" Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition x:Name="GraphPanelRow" Height="Auto" MinHeight="0"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*" MinHeight="120"/>
            </Grid.RowDefinitions>

            <!-- Node Graph Panel -->
            <Border Grid.Row="0" Background="{StaticResource BgSurface}" CornerRadius="8" Padding="4"
                    BorderThickness="1" Margin="0,0,0,5">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="GraphPanelBorder" Color="#2C2C2C"/>
                </Border.BorderBrush>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="GraphPanelBorder"
                                                Storyboard.TargetProperty="Color"
                                                To="#3A3A3A" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="GraphPanelBorder"
                                                Storyboard.TargetProperty="Color"
                                                To="#2C2C2C" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Bottom" Margin="8,0,8,2">
                        <Button x:Name="GraphCollapseBtn" Content="&#xE70D;"
                                Style="{StaticResource IconBtn}" DockPanel.Dock="Left"
                                VerticalAlignment="Center" Margin="0,0,4,0"
                                Click="GraphCollapse_Click" ToolTip="Expand graph"/>
                        <TextBlock Text="GRAPH" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                   FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"
                                   Margin="0,0,8,0" MouseLeftButtonDown="GraphHeader_MouseDown" Cursor="Hand"/>
                    </DockPanel>
                    <controls:TaskNodeGraphPanel x:Name="NodeGraphPanel" Visibility="Collapsed"/>
                </DockPanel>
            </Border>

            <!-- Splitter between graph and output -->
            <GridSplitter x:Name="GraphSplitter" Grid.Row="1" Height="3" HorizontalAlignment="Stretch"
                          VerticalAlignment="Center" Background="Transparent"
                          Style="{StaticResource HorizontalSplitter}" Visibility="Collapsed"/>

            <!-- Task Output -->
            <Border Grid.Row="2" Background="{StaticResource BgSurface}" CornerRadius="8" Padding="4"
                    BorderThickness="1" Margin="0,1,0,0">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="MainContentBorder" Color="#2C2C2C"/>
                </Border.BorderBrush>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="MainContentBorder"
                                                Storyboard.TargetProperty="Color"
                                                To="#3A3A3A" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="MainContentBorder"
                                                Storyboard.TargetProperty="Color"
                                                To="#2C2C2C" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="8,6,4,4">
                        <TextBlock Text="TASK OUTPUT" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                   FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                        <Button x:Name="ClearFinishedBtn" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                Content="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                Style="{StaticResource IconBtn}" ToolTip="Clear finished tasks"
                                Click="ClearFinishedTasks_Click" Padding="4,2" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TabControl x:Name="OutputTabs" Style="{StaticResource OutputTabControlStyle}"
                                SizeChanged="OutputTabs_SizeChanged"/>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══ FILE LOCKS PANEL ═══ -->
        <Thumb x:Name="ChatSplitter" Grid.Column="3" Grid.Row="0" Grid.RowSpan="5"
               Style="{StaticResource VerticalSplitterThumb}"
               DragDelta="ChatSplitter_DragDelta" Visibility="Collapsed"/>

        <Grid x:Name="ProjectsPanelGrid" Grid.Column="6" Grid.Row="2" Grid.RowSpan="3">
            <!-- Project Info panel -->
            <Border x:Name="FileLocksPanel" Background="{StaticResource BgSurface}" CornerRadius="8"
                    BorderBrush="{StaticResource BgElevated}" BorderThickness="1" Padding="8">
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                        <TextBlock Text="PROJECTS" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                   FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                    </DockPanel>
                    <TabControl x:Name="StatisticsTabs" Style="{StaticResource SettingsTabControlStyle}"
                                Background="Transparent" BorderThickness="0">
                        <!-- Projects tab -->
                        <TabItem x:Name="ProjectsTabItem">
                            <TabItem.Header>
                                <TextBlock Text="Projects" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                            </TabItem.Header>
                            <DockPanel Margin="0,6,0,0">
                                <!-- Add / Create Project buttons -->
                                <Border DockPanel.Dock="Bottom" Background="{StaticResource BgSection}" CornerRadius="6"
                                        BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1" Margin="0,6,0,0" Padding="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="6"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button Grid.Column="0" Content="Add Existing" Click="AddProjectBtn_Click"
                                                Background="{StaticResource Accent}" Style="{StaticResource SmallBtn}"
                                                HorizontalAlignment="Stretch" Padding="6,3" Height="24" FontSize="11"/>
                                        <Button Grid.Column="2" Content="Create New" Click="CreateProject_Click"
                                                Background="{StaticResource Accent}" Style="{StaticResource SmallBtn}"
                                                HorizontalAlignment="Stretch" Padding="6,3" Height="24" FontSize="11"/>
                                    </Grid>
                                </Border>
                                <!-- Project list -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled"
                                              CanContentScroll="True"
                                              PanningMode="VerticalOnly">
                                    <StackPanel x:Name="ProjectListPanel" Margin="0"
                                                VerticalAlignment="Top"/>
                                </ScrollViewer>
                            </DockPanel>
                        </TabItem>
                        <!-- File Locks tab -->
                        <TabItem x:Name="FileLocksTabItem">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="File Locks" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                                    <TextBlock x:Name="FileLockBadge" Text="0" Visibility="Collapsed"
                                               Foreground="{StaticResource WarningOrange}" FontSize="10" FontWeight="Bold"
                                               FontFamily="Segoe UI" Margin="4,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </TabItem.Header>
                            <DockPanel Margin="0,6,0,0">
                                <TextBlock DockPanel.Dock="Top" Text="Active file locks across all tasks"
                                           Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"
                                           Margin="0,0,0,8"/>
                                <!-- Lock rows with resizable columns -->
                                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                    <ListView x:Name="FileLocksListView" Style="{StaticResource FileLockListViewStyle}">
                                        <ListView.View>
                                            <GridView ColumnHeaderContainerStyle="{StaticResource FileLockColumnHeaderStyle}">
                                                <GridViewColumn Header="FILE" Width="160">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding FileName}"
                                                                       Foreground="{StaticResource TextLight}" FontSize="11" FontFamily="Consolas"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding OriginalPath}"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="TASK" Width="50">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding OwnerTaskNumber, StringFormat='#{0}'}"
                                                                       Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Consolas"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="STATUS" Width="70">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding StatusText}"
                                                                       FontSize="11" FontFamily="Consolas">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Setter Property="Foreground" Value="#4EC969"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding StatusText}" Value="Waiting">
                                                                                <Setter Property="Foreground" Value="{StaticResource WarningOrange}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsIgnored}" Value="True">
                                                                                <Setter Property="Foreground" Value="{StaticResource WarningOrange}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="TOOL" Width="90">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding ToolName}"
                                                                       Foreground="{StaticResource TextSecondary}" FontSize="11" FontFamily="Consolas"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="PATH" Width="200">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding OriginalPath}"
                                                                       Foreground="{StaticResource TextDim}" FontSize="11" FontFamily="Consolas"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="TASK" Width="70">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding OwnerTaskNumber, StringFormat='#{0}'}"
                                                                       Foreground="{StaticResource Accent}" FontSize="11" FontFamily="Consolas"/>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                                <GridViewColumn Header="SINCE" Width="70">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding TimeText}"
                                                                   Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Consolas"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                                </ScrollViewer>
                            </DockPanel>
                        </TabItem>
                        <!-- Git tab -->
                        <TabItem x:Name="GitTabItem">
                            <TabItem.Header>
                                <TextBlock Text="Git" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                            </TabItem.Header>
                            <ScrollViewer x:Name="GitTabContent" VerticalScrollBarVisibility="Auto" Padding="12"/>
                        </TabItem>
                        <!-- Features tab -->
                        <TabItem x:Name="FeaturesTabItem">
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Features" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                                    <TextBlock x:Name="FeaturesTabCount" FontWeight="Bold" FontSize="10"
                                               FontFamily="Segoe UI" Foreground="{StaticResource TextSubdued}"
                                               VerticalAlignment="Center" Margin="2,0,0,0"/>
                                </StackPanel>
                            </TabItem.Header>
                            <Grid x:Name="FeaturesPanelGrid" Margin="0,6,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition x:Name="FeaturesListRow" Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Action buttons -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,4">
                                    <Button DockPanel.Dock="Right" Content="Refresh" Click="RefreshFeatures_Click"
                                            Style="{StaticResource GhostBtn}"/>
                                    <Button x:Name="ReindexBtn" DockPanel.Dock="Right" Content="Re-index" Click="ReindexSymbols_Click"
                                            Style="{StaticResource GhostBtn}" ToolTip="Rebuild codebase symbol index from all features"/>
                                    <Button x:Name="ReassignBtn" DockPanel.Dock="Right" Content="Re-assign" Click="ReassignFeatures_Click"
                                            Style="{StaticResource GhostBtn}" ToolTip="Full feature re-initialization: rescan files, re-analyze with AI, rebuild registry"/>
                                </DockPanel>
                                <!-- Search box -->
                                <Grid Grid.Row="1" Margin="0,0,0,6">
                                    <TextBox x:Name="FeatureSearchBox"
                                             FontSize="12" Padding="6,4"
                                             Background="{StaticResource BgElevated}"
                                             Foreground="{StaticResource TextPrimary}"
                                             BorderThickness="1"
                                             TextChanged="FeatureSearchBox_TextChanged"/>
                                    <TextBlock Text="Search features..." IsHitTestVisible="False"
                                               FontSize="12" Padding="8,5"
                                               Foreground="{StaticResource TextSubdued}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=FeatureSearchBox}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <!-- Re-index progress bar -->
                                <Border x:Name="ReindexProgressBar" Grid.Row="2" Visibility="Collapsed"
                                        Background="{StaticResource BgElevated}" CornerRadius="4"
                                        Padding="6,4" Margin="0,0,0,4">
                                    <StackPanel>
                                        <TextBlock x:Name="ReindexProgressText"
                                                   FontSize="10" FontFamily="Segoe UI"
                                                   Foreground="{StaticResource TextSecondary}"
                                                   Margin="0,0,0,3"/>
                                        <ProgressBar x:Name="ReindexProgressValue"
                                                     Height="3" Minimum="0" Maximum="100"
                                                     Foreground="{StaticResource Accent}"
                                                     Background="{StaticResource BgDeep}"
                                                     BorderThickness="0"/>
                                    </StackPanel>
                                </Border>
                                <!-- Feature health status bar -->
                                <Border x:Name="FeatureHealthBar" Grid.Row="3" Visibility="Collapsed"
                                        Background="{StaticResource BgElevated}" CornerRadius="4"
                                        Padding="6,3" Margin="0,0,0,4">
                                    <TextBlock x:Name="FeatureHealthText"
                                               FontSize="10" FontFamily="Segoe UI"
                                               Foreground="{StaticResource TextSecondary}"
                                               TextWrapping="Wrap"/>
                                </Border>
                                <!-- Feature list -->
                                <ListBox x:Name="FeaturesListBox" Grid.Row="4"
                                         Style="{StaticResource TaskListStyle}"
                                         SelectionChanged="FeaturesListBox_SelectionChanged"
                                         PreviewMouseWheel="TaskList_PreviewMouseWheel"
                                         PreviewMouseRightButtonDown="FeaturesListBox_PreviewMouseRightButtonDown">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Padding="6,4" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="{StaticResource BgElevated}"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Update Signatures" Click="UpdateFeature_Click"/>
                                                        <MenuItem Header="Full Update" Click="FullUpdateFeature_Click"/>
                                                        <MenuItem Header="Copy Feature ID" Click="CopyFeatureId_Click"/>
                                                        <Separator/>
                                                        <MenuItem Header="Remove Feature" Click="RemoveFeature_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <StackPanel>
                                                    <DockPanel>
                                                        <TextBlock DockPanel.Dock="Right" Text="{Binding Category}"
                                                                   Foreground="{StaticResource AccentTeal}" FontSize="9"
                                                                   FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding Name}" Foreground="{StaticResource TextBright}"
                                                                   FontSize="12" FontFamily="Segoe UI" FontWeight="SemiBold"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </DockPanel>
                                                    <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondary}"
                                                               FontSize="10" FontFamily="Segoe UI" TextTrimming="CharacterEllipsis"
                                                               MaxHeight="30" Margin="0,2,0,0"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                <!-- Feature detail panel -->
                                <Border x:Name="FeatureDetailPanel" Grid.Row="5" Visibility="Collapsed"
                                        Background="{StaticResource BgDeep}" CornerRadius="6" Padding="10"
                                        Margin="0,6,0,0" MaxHeight="280"
                                        BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,4">
                                                <Button DockPanel.Dock="Right" Content="&#xE711;"
                                                        Style="{StaticResource IconBtn}" FontSize="10"
                                                        VerticalAlignment="Top" Margin="4,0,0,0"
                                                        Click="CloseFeatureDetail_Click" ToolTip="Close detail"/>
                                                <Border DockPanel.Dock="Right" Background="{StaticResource BgElevated}"
                                                        CornerRadius="3" Padding="6,2">
                                                    <TextBlock x:Name="FeatureDetailCategory" Foreground="{StaticResource AccentTeal}"
                                                               FontSize="10" FontFamily="Segoe UI"/>
                                                </Border>
                                                <TextBlock x:Name="FeatureDetailName" Foreground="{StaticResource Accent}"
                                                           FontSize="14" FontWeight="Bold" FontFamily="Segoe UI"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                            <TextBlock x:Name="FeatureDetailDescription" Foreground="{StaticResource TextBody}"
                                                       FontSize="11" FontFamily="Segoe UI" TextWrapping="Wrap"
                                                       Margin="0,0,0,8"/>
                                            <TextBlock Text="KEYWORDS" Foreground="{StaticResource TextDim}" FontSize="9"
                                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="FeatureDetailKeywords" Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <TextBlock Text="RELATED FEATURES" Foreground="{StaticResource TextDim}" FontSize="9"
                                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="FeatureDetailRelated" Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <TextBlock Text="DEPENDS ON" Foreground="{StaticResource TextDim}" FontSize="9"
                                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="FeatureDetailDependsOn" Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <TextBlock Text="DEPENDENCIES" Foreground="{StaticResource TextDim}" FontSize="9"
                                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="FeatureDetailDependencies" Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <TextBlock Text="KEY TYPES" Foreground="{StaticResource TextDim}" FontSize="9"
                                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="FeatureDetailKeyTypes" Foreground="{StaticResource AccentBlue}"
                                                       FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <TextBlock Text="PATTERNS" Foreground="{StaticResource TextDim}" FontSize="9"
                                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="FeatureDetailPatterns" Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <TextBlock Text="PRIMARY FILES" Foreground="{StaticResource TextDim}" FontSize="9"
                                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="FeatureDetailPrimaryFiles" Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <TextBlock Text="SECONDARY FILES" Foreground="{StaticResource TextDim}" FontSize="9"
                                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="FeatureDetailSecondaryFiles" Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <TextBlock Text="SIGNATURES" Foreground="{StaticResource TextDim}" FontSize="9"
                                                       FontWeight="Bold" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                            <TextBlock x:Name="FeatureDetailSignatures" Foreground="{StaticResource TextSecondary}"
                                                       FontSize="10" FontFamily="Consolas" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                            <TextBlock x:Name="FeatureDetailMeta" Foreground="{StaticResource TextDisabled}"
                                                       FontSize="9" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                        </StackPanel>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </TabItem>
                        <!-- Tasks tab -->
                        <TabItem x:Name="TasksTabItem">
                            <TabItem.Header>
                                <TextBlock Text="Tasks" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                            </TabItem.Header>
                            <Grid>
                                <!-- No project overlay -->
                                <StackPanel x:Name="NoProjectTasksOverlay" Visibility="Collapsed"
                                            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="32"
                                               Foreground="{StaticResource TextDim}" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <TextBlock Text="No project selected" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondary}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                    <TextBlock Text="Add a project to manage tasks" FontSize="12"
                                               Foreground="{StaticResource TextDim}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- Task content -->
                                <DockPanel x:Name="TaskContentPanel" Margin="0,6,0,0">
                                <!-- Input area -->
                                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                    <Button x:Name="AddTaskBtn" Content="Add" Click="AddTask_Click"
                                            Style="{StaticResource SmallBtn}" DockPanel.Dock="Right"
                                            Margin="8,0,0,0" Width="50">
                                        <Button.Background>
                                            <StaticResource ResourceKey="Accent"/>
                                        </Button.Background>
                                    </Button>
                                    <TextBox x:Name="TaskInputBox"
                                             FontSize="12" Padding="8,6"
                                             Background="{StaticResource BgDeep}"
                                             Foreground="{StaticResource TextPrimary}"
                                             CaretBrush="{StaticResource TextPrimary}"
                                             BorderBrush="{StaticResource BorderSubtle}"
                                             BorderThickness="1"
                                             KeyDown="TaskInput_KeyDown">
                                        <TextBox.Tag>
                                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Add a new task...</sys:String>
                                        </TextBox.Tag>
                                    </TextBox>
                                </DockPanel>

                                <!-- Task list -->
                                <ListBox x:Name="TaskListControl"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         ScrollViewer.CanContentScroll="True"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         VirtualizingPanel.ScrollUnit="Pixel"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <VirtualizingStackPanel/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <ContentPresenter/>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="Margin" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border x:Name="TaskItemBorder"
                                                    Background="{StaticResource BgSurface}"
                                                    CornerRadius="6"
                                                    Padding="12,8"
                                                    Margin="0,0,0,4"
                                                    Cursor="Hand"
                                                    MouseLeftButtonUp="TaskItem_Click">
                                                <Border.Triggers>
                                                    <EventTrigger RoutedEvent="MouseEnter">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                To="#2A2A2A" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                    <EventTrigger RoutedEvent="MouseLeave">
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <ColorAnimation Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                                                                To="#1F1F1F" Duration="0:0:0.15"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </EventTrigger>
                                                </Border.Triggers>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Checkbox visual -->
                                                    <Border Grid.Column="0" Width="16" Height="16"
                                                            BorderThickness="2" CornerRadius="3"
                                                            BorderBrush="{StaticResource TextDim}"
                                                            Background="Transparent"
                                                            Margin="0,0,10,0">
                                                        <Path x:Name="CheckMark"
                                                              Data="M 2,6 L 6,10 L 14,2"
                                                              Stroke="{StaticResource Accent}"
                                                              StrokeThickness="2"
                                                              Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibility}}"/>
                                                    </Border>

                                                    <!-- Task text -->
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Text}"
                                                               Foreground="{StaticResource TextLight}"
                                                               FontSize="12"
                                                               FontFamily="Segoe UI"
                                                               VerticalAlignment="Center"
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                        <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Remove button -->
                                                    <Button Grid.Column="2"
                                                            Content="&#xE711;"
                                                            Click="RemoveTask_Click"
                                                            Margin="10,0,0,0"
                                                            ToolTip="Remove task">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource IconBtn}">
                                                                <Setter Property="FontSize" Value="12"/>
                                                                <Setter Property="Foreground" Value="{StaticResource TextDim}"/>
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=IsMouseOver}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource Error}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                    </Button>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                                </DockPanel>
                            </Grid>
                        </TabItem>
                        <!-- Activity tab -->
                        <TabItem x:Name="ActivityTabItem">
                            <TabItem.Header>
                                <TextBlock Text="Activity" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                            </TabItem.Header>
                            <ScrollViewer x:Name="ActivityTabContent" VerticalScrollBarVisibility="Auto" Padding="12"/>
                        </TabItem>
                        <!-- IDE tab -->
                        <TabItem x:Name="IdeTabItem">
                            <TabItem.Header>
                                <TextBlock Text="IDE" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                            </TabItem.Header>
                            <ScrollViewer x:Name="IdeTabContent" VerticalScrollBarVisibility="Auto" Padding="12"/>
                        </TabItem>
                        <!-- MCP tab -->
                        <TabItem x:Name="McpProjectTabItem" Visibility="Collapsed">
                            <TabItem.Header>
                                <TextBlock Text="MCP" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                            </TabItem.Header>
                            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10,6,10,10">
                                <StackPanel MaxWidth="500">
                                    <!-- Per-project MCP settings -->
                                    <TextBlock Text="Server Settings" Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                               FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,8"/>

                                    <TextBlock Text="Server Name" Foreground="{StaticResource TextSubdued}"
                                               FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                    <TextBox x:Name="McpServerNameBox"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             FontSize="11" FontFamily="Segoe UI" Padding="6,4" Margin="0,0,0,8"
                                             LostFocus="McpSettings_Changed"/>

                                    <TextBlock Text="Server Address" Foreground="{StaticResource TextSubdued}"
                                               FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                    <TextBox x:Name="McpAddressBox"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             FontSize="11" FontFamily="Segoe UI" Padding="6,4" Margin="0,0,0,8"
                                             LostFocus="McpSettings_Changed"/>

                                    <TextBlock Text="Start Command" Foreground="{StaticResource TextSubdued}"
                                               FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                    <TextBox x:Name="McpStartCommandBox"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             FontSize="11" FontFamily="Consolas" Padding="6,4" Margin="0,0,0,8"
                                             TextWrapping="Wrap" AcceptsReturn="False"
                                             LostFocus="McpSettings_Changed"/>

                                    <!-- Connection test -->
                                    <DockPanel Margin="0,0,0,8">
                                        <Button x:Name="McpTestConnectionBtn" Content="Test Connection"
                                                Click="McpTestConnection_Click"
                                                Style="{StaticResource SecondaryBtn}"
                                                FontSize="11" Padding="10,4"
                                                DockPanel.Dock="Left"/>
                                        <TextBlock x:Name="McpConnectionStatus"
                                                   Foreground="{StaticResource TextMuted}"
                                                   FontSize="11" FontFamily="Segoe UI"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </DockPanel>

                                    <Border Height="1" Background="{StaticResource BgElevated}" Margin="0,4,0,10"/>

                                    <!-- MCP Defaults -->
                                    <TextBlock Text="Defaults for New Projects" Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                               FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,8"/>

                                    <TextBlock Text="Default Server Name" Foreground="{StaticResource TextSubdued}"
                                               FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                    <TextBox x:Name="DefaultMcpServerNameBox" Text="UnityMCP"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             FontSize="11" FontFamily="Segoe UI" Padding="6,4" Margin="0,0,0,8"
                                             LostFocus="DefaultMcpSettings_Changed"/>

                                    <TextBlock Text="Default Server Address" Foreground="{StaticResource TextSubdued}"
                                               FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                    <TextBox x:Name="DefaultMcpAddressBox" Text="http://127.0.0.1:8080/mcp"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             FontSize="11" FontFamily="Segoe UI" Padding="6,4" Margin="0,0,0,8"
                                             LostFocus="DefaultMcpSettings_Changed"/>

                                    <TextBlock Text="Default Start Command" Foreground="{StaticResource TextSubdued}"
                                               FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,2"/>
                                    <TextBox x:Name="DefaultMcpStartCommandBox"
                                             Text='%USERPROFILE%\.local\bin\uvx.exe --from "mcpforunityserver==9.4.7" mcp-for-unity --transport http --http-url http://127.0.0.1:8080 --project-scoped-tools'
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             FontSize="11" FontFamily="Consolas" Padding="6,4" Margin="0,0,0,4"
                                             TextWrapping="Wrap" AcceptsReturn="False"
                                             LostFocus="DefaultMcpSettings_Changed"/>
                                    <TextBlock Text="These values auto-populate when creating new projects."
                                               Foreground="{StaticResource TextDisabled}" FontSize="11" FontFamily="Segoe UI"
                                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                                    <Border Height="1" Background="{StaticResource BgElevated}" Margin="0,0,0,10"/>

                                    <!-- Server Output -->
                                    <TextBlock Text="Server Output" Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                               FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                    <Border CornerRadius="4" Background="{StaticResource BgDarkTerminal}" MinHeight="100" MaxHeight="300">
                                        <ScrollViewer x:Name="McpOutputScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                                            <TextBox x:Name="McpOutputTextBox"
                                                     IsReadOnly="True"
                                                     FontFamily="Consolas"
                                                     FontSize="11"
                                                     Background="{StaticResource BgDarkTerminal}"
                                                     Foreground="{StaticResource TextTerminal}"
                                                     BorderThickness="0"
                                                     Padding="8"
                                                     TextWrapping="NoWrap"
                                                     AcceptsReturn="True"
                                                     VerticalScrollBarVisibility="Hidden"
                                                     HorizontalScrollBarVisibility="Hidden"/>
                                        </ScrollViewer>
                                    </Border>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Vertical Splitter: Center ↔ Right (Thumb-based to avoid GridSplitter col-4 mis-targeting) -->
        <Thumb x:Name="RightSplitter" Grid.Column="5" Grid.Row="0" Grid.RowSpan="5"
               Style="{StaticResource VerticalSplitterThumb}"
               DragDelta="RightSplitter_DragDelta"/>

        <!-- ═══ SETTINGS (5) ═══ -->
        <!-- Collapsed strip (shown when panel is collapsed). Lives in the splitter column so the right panel column can fully collapse. -->
        <Border x:Name="SettingsCollapsedStrip" Grid.Row="0" Grid.Column="5" Grid.RowSpan="5"
                Background="{StaticResource BgSurface}" CornerRadius="8" Padding="0" Visibility="Collapsed"
                BorderThickness="1" BorderBrush="{StaticResource BgElevated}" Width="32"
                Margin="3,0,0,0">
            <Button x:Name="ExpandSettingsBtn" Click="ToggleSettingsPanel_Click"
                    ToolTip="Expand Settings" VerticalAlignment="Top" HorizontalAlignment="Center"
                    Margin="0,6,0,0">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource IconBtn}">
                        <Setter Property="Content" Value="&#xE76B;"/>
                        <Setter Property="FontSize" Value="12"/>
                        <Setter Property="Foreground" Value="{StaticResource Accent}"/>
                    </Style>
                </Button.Style>
            </Button>
        </Border>
        <!-- Expanded settings panel -->
        <Border x:Name="SettingsExpandedPanel" Grid.Row="0" Grid.Column="6" Background="{StaticResource BgSurface}" CornerRadius="8" Padding="4"
                BorderThickness="1">
                <Border.BorderBrush>
                    <SolidColorBrush x:Name="RightPanelBorder" Color="#2C2C2C"/>
                </Border.BorderBrush>
                <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="RightPanelBorder"
                                                Storyboard.TargetProperty="Color"
                                                To="#3A3A3A" Duration="0:0:0.2"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                        <BeginStoryboard>
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetName="RightPanelBorder"
                                                Storyboard.TargetProperty="Color"
                                                To="#2C2C2C" Duration="0:0:0.3"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </EventTrigger>
                </Border.Triggers>
                <DockPanel>
                    <DockPanel DockPanel.Dock="Top" Margin="8,6,4,4">
                        <Button Click="ToggleSettingsPanel_Click" ToolTip="Collapse Settings"
                                DockPanel.Dock="Left" VerticalAlignment="Center">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource IconBtn}">
                                    <Setter Property="Content" Value="&#xE76C;"/>
                                    <Setter Property="FontSize" Value="12"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
                                </Style>
                            </Button.Style>
                        </Button>
                        <TextBlock Text="SETTINGS" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                   FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </DockPanel>
                <TabControl x:Name="MainTabs" Style="{StaticResource SettingsTabControlStyle}"
                            Background="Transparent" BorderThickness="0">
                    <!-- Build tab -->
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Build" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                            <StackPanel MaxWidth="600">
                                <!-- Build Tools section -->
                                <TextBlock Text="BUILD TOOLS" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                           FontSize="13" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <TextBlock Text="Investigate build failures, crash logs, and verify project tests."
                                           Foreground="{StaticResource TextSubdued}" FontSize="11" FontFamily="Segoe UI" TextWrapping="Wrap"
                                           Margin="0,0,0,16"/>
                                <WrapPanel Orientation="Horizontal">
                                    <Button x:Name="BuildInvestigationBtn" Content="Crash Log Investigation"
                                            Click="BuildInvestigation_Click"
                                            Style="{StaticResource SecondaryBtn}"
                                            FontSize="11" Padding="10,4" Margin="0,0,8,6"/>
                                    <Button x:Name="TestVerificationBtn" Content="Test Verification"
                                            Click="TestVerification_Click"
                                            Style="{StaticResource SecondaryBtn}"
                                            FontSize="11" Padding="10,4" Margin="0,0,8,6"/>
                                    <Button x:Name="BuildTestBtn" Content="Build Test"
                                            Click="BuildTest_Click"
                                            Style="{StaticResource SecondaryBtn}"
                                            FontSize="11" Padding="10,4" Margin="0,0,8,6"/>
                                    <Button x:Name="RestartProjectBtn" Content="Restart Project"
                                            Click="RestartProject_Click"
                                            Style="{StaticResource SecondaryBtn}"
                                            FontSize="11" Padding="10,4" Margin="0,0,8,6"/>
                                </WrapPanel>

                                <Border Height="1" Background="{StaticResource BgElevated}" Margin="0,12,0,12"/>

                                <!-- Export Build section -->
                                <TextBlock Text="BUILD EXPORT" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                           FontSize="13" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <TextBlock Text="Export your application for distribution." Foreground="{StaticResource TextMuted}"
                                           FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,16" TextWrapping="Wrap"/>
                                <Button x:Name="ExportBuildBtn" Content="Export Build" Click="ExportBuild_Click"
                                        Background="{StaticResource Accent}" Style="{StaticResource SmallBtn}"
                                        Padding="12,6" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="ExportStatusText" Foreground="{StaticResource TextMuted}" FontSize="11"
                                           FontFamily="Segoe UI" Margin="0,12,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <!-- Automation tab -->
                    <TabItem x:Name="HelperTabItem">
                        <TabItem.Header>
                            <TextBlock Text="Automation" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="12">
                            <StackPanel>
                            <!-- Top controls -->
                            <StackPanel Margin="0,0,0,12">
                                <TextBlock Text="Project Suggestions" Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                           FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,6"/>
                                <TextBlock Text="Analyze the current project and generate actionable suggestions for improvements."
                                           Foreground="{StaticResource TextSubdued}" FontSize="11" FontFamily="Segoe UI" TextWrapping="Wrap"
                                           Margin="0,0,0,12"/>

                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="Category" Foreground="{StaticResource TextLight}" FontSize="11"
                                               FontFamily="Segoe UI" VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <ComboBox x:Name="HelperCategoryCombo" Width="160"
                                              FontSize="11" Padding="6,3" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="General" Tag="General" IsSelected="True"/>
                                        <ComboBoxItem Content="Bug Fixes" Tag="BugFixes"/>
                                        <ComboBoxItem Content="New Features" Tag="NewFeatures"/>
                                        <ComboBoxItem Content="Extensions" Tag="Extensions"/>
                                        <ComboBoxItem Content="Rules" Tag="Rules"/>
                                    </ComboBox>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="Model" Foreground="{StaticResource TextLight}" FontSize="11"
                                               FontFamily="Segoe UI" VerticalAlignment="Center"
                                               Margin="0,0,10,0" Width="52"/>
                                    <ComboBox x:Name="SuggestionModelCombo" Width="160"
                                              FontSize="11" Padding="6,3" HorizontalAlignment="Left">
                                        <ComboBoxItem Content="Sonnet" Tag="Sonnet" IsSelected="True"/>
                                        <ComboBoxItem Content="Haiku" Tag="Haiku"/>
                                        <ComboBoxItem Content="Opus" Tag="Opus"/>
                                    </ComboBox>
                                </DockPanel>

                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="Guidance" Foreground="{StaticResource TextLight}" FontSize="11"
                                               FontFamily="Segoe UI" VerticalAlignment="Center"
                                               Margin="0,0,10,0"/>
                                    <Grid>
                                        <TextBox x:Name="SuggestionGuidanceInput"
                                                 FontSize="11" FontFamily="Segoe UI" Padding="6,4"
                                                 Background="{StaticResource BgSection}" Foreground="{StaticResource TextLight}"
                                                 BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                                 VerticalAlignment="Center"
                                                 PreviewKeyDown="SuggestionGuidanceInput_PreviewKeyDown"/>
                                        <TextBlock Text="Optional: guide the suggestions (e.g. &quot;focus on error handling&quot;)"
                                                   Foreground="{StaticResource TextSubdued}" FontSize="11" FontFamily="Segoe UI"
                                                   Padding="8,5" IsHitTestVisible="False" VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Text, ElementName=SuggestionGuidanceInput}" Value="">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </Grid>
                                </DockPanel>

                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="GenerateSuggestionsBtn" Content="Generate Suggestions"
                                            Click="GenerateSuggestions_Click"
                                            Background="{StaticResource Accent}" Style="{StaticResource SmallBtn}"
                                            Padding="10,4"/>
                                    <Button x:Name="ClearSuggestionsBtn" Content="Clear All"
                                            Click="ClearSuggestions_Click"
                                            Style="{StaticResource GhostBtn}"
                                            FontSize="11" Padding="12,6" Margin="8,0,0,0"/>
                                    <TextBlock x:Name="HelperStatusText" Text=""
                                               Foreground="{StaticResource TextSubdued}" FontSize="11" FontFamily="Segoe UI"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </StackPanel>
                            </StackPanel>

                            <Border Height="1" Background="{StaticResource BgElevated}" Margin="0,0,0,8"/>

                            <!-- Suggestions list -->
                                <ItemsControl x:Name="SuggestionsListView">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="12,10" Margin="0,3"
                                                    Background="{StaticResource BgSection}" BorderThickness="1" BorderBrush="{StaticResource BgElevated}">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Copy" Tag="{Binding}"
                                                                  Click="CopySuggestion_Click"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <DockPanel>
                                                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center"
                                                                Margin="10,0,0,0">
                                                        <Button Content="Run" Tag="{Binding}"
                                                                Click="RunSuggestion_Click"
                                                                Background="{StaticResource Accent}" Style="{StaticResource SmallBtn}"
                                                                Padding="10,4" Margin="0,0,0,4"/>
                                                        <Button Content="Save" Tag="{Binding}"
                                                                Click="SaveSuggestion_Click"
                                                                Style="{StaticResource GhostBtn}"
                                                                FontSize="10" Padding="10,3" Margin="0,0,0,4"/>
                                                        <Button Content="Remove" Tag="{Binding}"
                                                                Click="RemoveSuggestion_Click"
                                                                Style="{StaticResource GhostBtn}"
                                                                FontSize="10" Padding="10,3" Margin="0,0,0,4"/>
                                                        <Button Content="Ignore" Tag="{Binding}"
                                                                Click="IgnoreSuggestion_Click"
                                                                Style="{StaticResource GhostBtn}"
                                                                FontSize="10" Padding="10,3"/>
                                                    </StackPanel>
                                                    <StackPanel>
                                                        <DockPanel Margin="0,0,0,4">
                                                            <Border CornerRadius="3" Padding="6,2" Margin="0,0,8,0"
                                                                    VerticalAlignment="Center">
                                                                <Border.Style>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="Background" Value="{StaticResource BorderSubtle}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Category}" Value="BugFixes">
                                                                                <Setter Property="Background" Value="#3A2020"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Category}" Value="NewFeatures">
                                                                                <Setter Property="Background" Value="#1A3A20"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Category}" Value="Extensions">
                                                                                <Setter Property="Background" Value="#1A2040"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Category}" Value="Rules">
                                                                                <Setter Property="Background" Value="#2A2A1A"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock FontSize="10" FontFamily="Segoe UI"
                                                                           FontWeight="SemiBold">
                                                                    <TextBlock.Style>
                                                                        <Style TargetType="TextBlock">
                                                                            <Setter Property="Text" Value="{Binding Category}"/>
                                                                            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding Category}" Value="BugFixes">
                                                                                    <Setter Property="Foreground" Value="{StaticResource DangerBright}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Category}" Value="NewFeatures">
                                                                                    <Setter Property="Foreground" Value="#4EC969"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Category}" Value="Extensions">
                                                                                    <Setter Property="Foreground" Value="{StaticResource PausedBlue}"/>
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding Category}" Value="Rules">
                                                                                    <Setter Property="Foreground" Value="#D4C44D"/>
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </TextBlock.Style>
                                                                </TextBlock>
                                                            </Border>
                                                            <TextBlock Text="{Binding Title}" Foreground="#DDD"
                                                                       FontSize="13" FontWeight="SemiBold"
                                                                       FontFamily="Segoe UI"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTip="{Binding Title}"/>
                                                        </DockPanel>
                                                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondary}"
                                                                   FontSize="11" FontFamily="Segoe UI"
                                                                   TextWrapping="Wrap">
                                                            <TextBlock.ToolTip>
                                                                <TextBlock Text="{Binding Description}" MaxWidth="400" TextWrapping="Wrap"/>
                                                            </TextBlock.ToolTip>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <!-- Advanced tab -->
                    <TabItem x:Name="AdvancedTabItem">
                        <TabItem.Header>
                            <TextBlock Text="Advanced" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                            <StackPanel MaxWidth="600">
                                <DockPanel Margin="0,0,0,8">
                                    <TextBlock Text="System Prompt" Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                    <ToggleButton x:Name="EditSystemPromptToggle"
                                                  Style="{StaticResource ToggleSwitch}" Margin="12,0,0,0"
                                                  Checked="EditSystemPromptToggle_Changed"
                                                  Unchecked="EditSystemPromptToggle_Changed">
                                        <TextBlock Text="Edit" Foreground="{StaticResource TextSubdued}" FontSize="11" FontFamily="Segoe UI"/>
                                    </ToggleButton>
                                </DockPanel>
                                <TextBox x:Name="SystemPromptBox" AcceptsReturn="True" TextWrapping="Wrap"
                                         MinHeight="160" MaxHeight="300"
                                         VerticalScrollBarVisibility="Auto"
                                         Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                         CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                         FontSize="11" FontFamily="Consolas" Padding="10"
                                         IsReadOnly="True" Opacity="0.6"/>
                                <DockPanel Margin="0,6,0,0">
                                    <TextBlock Text="This prompt is prepended to every task."
                                               Foreground="{StaticResource TextDisabled}" FontSize="11" FontFamily="Segoe UI"
                                               VerticalAlignment="Center"/>
                                    <StackPanel x:Name="PromptEditButtons" Orientation="Horizontal"
                                                HorizontalAlignment="Right" Visibility="Collapsed">
                                        <Button x:Name="ResetPromptBtn" Content="Reset" Click="ResetPrompt_Click"
                                                Style="{StaticResource GhostBtn}" Margin="0,0,6,0"
                                                Padding="12,4" FontSize="11"/>
                                        <Button x:Name="SavePromptBtn" Content="Save" Click="SavePrompt_Click"
                                                Style="{StaticResource SuccessBtn}"
                                                Padding="12,4" FontSize="11"/>
                                    </StackPanel>
                                </DockPanel>

                                <!-- Project-specific settings (hidden, accessed via gear icon on project cards) -->
                                <StackPanel Visibility="Collapsed">
                                    <ToggleButton x:Name="EditShortDescToggle" Style="{StaticResource ToggleSwitch}"
                                                  Checked="EditShortDescToggle_Changed" Unchecked="EditShortDescToggle_Changed"/>
                                    <TextBox x:Name="ShortDescBox"/>
                                    <StackPanel x:Name="ShortDescEditButtons" Orientation="Horizontal" Visibility="Collapsed">
                                        <Button Content="Save" Click="SaveShortDesc_Click" Style="{StaticResource SuccessBtn}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="EditLongDescToggle" Style="{StaticResource ToggleSwitch}"
                                                  Checked="EditLongDescToggle_Changed" Unchecked="EditLongDescToggle_Changed"/>
                                    <TextBox x:Name="LongDescBox"/>
                                    <StackPanel x:Name="LongDescEditButtons" Orientation="Horizontal" Visibility="Collapsed">
                                        <Button Content="Save" Click="SaveLongDesc_Click" Style="{StaticResource SuccessBtn}"/>
                                    </StackPanel>
                                    <Button x:Name="RegenerateDescBtn" Content="Regenerate" Click="RegenerateDescriptions_Click"
                                            Style="{StaticResource SecondaryBtn}"/>
                                    <ToggleButton x:Name="EditRuleInstructionToggle" Style="{StaticResource ToggleSwitch}"
                                                  Checked="EditRuleInstructionToggle_Changed" Unchecked="EditRuleInstructionToggle_Changed"/>
                                    <TextBox x:Name="RuleInstructionBox"/>
                                    <StackPanel x:Name="RuleInstructionEditButtons" Orientation="Horizontal" Visibility="Collapsed">
                                        <Button Content="Save" Click="SaveRuleInstruction_Click" Style="{StaticResource SuccessBtn}"/>
                                    </StackPanel>
                                    <ItemsControl x:Name="ProjectRulesList"/>
                                    <TextBox x:Name="NewRuleInput" KeyDown="NewRuleInput_KeyDown"/>
                                    <ToggleButton x:Name="ProjectTypeGameToggle" Style="{StaticResource ToggleSwitch}"
                                                  Checked="ProjectTypeGameToggle_Changed" Unchecked="ProjectTypeGameToggle_Changed"/>
                                    <ToggleButton x:Name="EditCrashLogPathsToggle" Style="{StaticResource ToggleSwitch}"
                                                  Checked="EditCrashLogPathsToggle_Changed" Unchecked="EditCrashLogPathsToggle_Changed"/>
                                    <TextBox x:Name="CrashLogPathBox"/>
                                    <TextBox x:Name="AppLogPathBox"/>
                                    <TextBox x:Name="HangLogPathBox"/>
                                    <StackPanel x:Name="CrashLogPathsEditButtons" Orientation="Horizontal" Visibility="Collapsed">
                                        <Button Content="Reset" Click="ResetCrashLogPaths_Click" Style="{StaticResource SecondaryBtn}" Margin="0,0,6,0"/>
                                        <Button Content="Save" Click="SaveCrashLogPaths_Click" Style="{StaticResource SuccessBtn}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Height="1" Background="{StaticResource BgElevated}" Margin="0,20,0,10"/>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Max concurrent tasks" Foreground="{StaticResource TextLight}"
                                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <TextBox x:Name="MaxConcurrentTasksBox" Width="60" Text="10"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             FontSize="11" FontFamily="Segoe UI" Padding="6,4"
                                             TextAlignment="Center"
                                             LostFocus="MaxConcurrentTasks_Changed"
                                             KeyDown="MaxConcurrentTasks_KeyDown"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="History retention" Foreground="{StaticResource TextLight}"
                                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <ComboBox x:Name="HistoryRetentionCombo" Width="120"
                                              FontSize="11" Padding="6,3"
                                              SelectionChanged="HistoryRetention_Changed">
                                        <ComboBoxItem Content="6 hours" Tag="6"/>
                                        <ComboBoxItem Content="12 hours" Tag="12"/>
                                        <ComboBoxItem Content="24 hours" Tag="24" IsSelected="True"/>
                                        <ComboBoxItem Content="3 days" Tag="72"/>
                                        <ComboBoxItem Content="7 days" Tag="168"/>
                                    </ComboBox>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Token limit retry (min)" Foreground="{StaticResource TextLight}"
                                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <TextBox x:Name="TokenLimitRetryBox" Width="60" Text="30"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             FontSize="11" FontFamily="Segoe UI" Padding="6,4"
                                             TextAlignment="Center"
                                             LostFocus="TokenLimitRetry_Changed"
                                             KeyDown="TokenLimitRetry_KeyDown"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Task timeout (min)" Foreground="{StaticResource TextLight}"
                                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <TextBox x:Name="TaskTimeoutBox" Width="60" Text="120"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             FontSize="11" FontFamily="Segoe UI" Padding="6,4"
                                             TextAlignment="Center"
                                             PreviewTextInput="TimeoutBox_PreviewTextInput"
                                             LostFocus="TaskTimeout_Changed"
                                             KeyDown="TaskTimeout_KeyDown"
                                             ToolTip="Task timeout in minutes (default: 120)"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Opus effort level" Foreground="{StaticResource TextLight}"
                                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"
                                               Margin="0,0,12,0"/>
                                    <ComboBox x:Name="OpusEffortCombo" Width="120"
                                              FontSize="11" Padding="6,3"
                                              SelectionChanged="OpusEffort_Changed">
                                        <ComboBoxItem Content="Low" Tag="low"/>
                                        <ComboBoxItem Content="Medium" Tag="medium"/>
                                        <ComboBoxItem Content="High" Tag="high" IsSelected="True"/>
                                    </ComboBox>
                                </StackPanel>

                                <DockPanel Margin="0,0,0,10">
                                    <ToggleButton x:Name="ShowCodeChangesToggle" IsChecked="False"
                                                  Style="{StaticResource ToggleSwitch}"
                                                  Checked="ShowCodeChangesToggle_Changed"
                                                  Unchecked="ShowCodeChangesToggle_Changed"
                                                  DockPanel.Dock="Right" Margin="12,0,0,0"/>
                                    <TextBlock Text="See Code Changes" Foreground="{StaticResource TextLight}"
                                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </DockPanel>

                                <Border Height="1" Background="{StaticResource BgElevated}" Margin="0,10,0,10"/>

                                <TextBlock Text="Diagnostics" Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                           FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <Button x:Name="ViewLogsBtn" Content="View Application Log"
                                        Click="ViewLogs_Click"
                                        Style="{StaticResource SecondaryBtn}"
                                        FontSize="11"
                                        HorizontalAlignment="Left"
                                        Padding="10,4"/>
                                <Button Content="View Activity Dashboard"
                                        Click="ViewActivity_Click"
                                        Style="{StaticResource SecondaryBtn}"
                                        FontSize="11"
                                        HorizontalAlignment="Left"
                                        Padding="10,4" Margin="0,6,0,0"/>
                                <Button Content="Clear All Ignored Suggestions"
                                        Click="ClearIgnoredSuggestions_Click"
                                        Style="{StaticResource SecondaryBtn}"
                                        FontSize="11"
                                        HorizontalAlignment="Left"
                                        Padding="10,4" Margin="0,6,0,0"/>

                                <Border Height="1" Background="{StaticResource BgElevated}" Margin="0,10,0,20"/>

                                <TextBlock Text="About" Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI"/>
                                <TextBlock Text="Spritely - Claude Code Task Manager" Foreground="{StaticResource TextDisabled}"
                                           FontSize="11" FontFamily="Segoe UI" Margin="0,4,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <!-- Models tab (Combined Claude and Gemini) -->
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Models" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                            <StackPanel MaxWidth="600">
                                <!-- Claude Section -->
                                <TextBlock Text="CLAUDE CHAT API" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                           FontSize="13" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <TextBlock Text="Configure an Anthropic API key to use Claude models in the Chat tab."
                                           Foreground="{StaticResource TextSubdued}" FontSize="11" FontFamily="Segoe UI" TextWrapping="Wrap"
                                           Margin="0,0,0,16"/>

                                <TextBlock Text="API Key" Foreground="{StaticResource TextLight}" FontSize="11" FontFamily="Segoe UI"
                                           Margin="0,0,0,6"/>
                                <DockPanel Margin="0,0,0,4">
                                    <Button x:Name="SaveClaudeKeyBtn" Content="Save" Click="SaveClaudeKey_Click"
                                            Style="{StaticResource SmallBtn}" DockPanel.Dock="Right"
                                            Background="{StaticResource Accent}" Padding="10,4" Margin="6,0,0,0"/>
                                    <TextBox x:Name="ClaudeApiKeyBox"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             FontSize="11" FontFamily="Consolas" Padding="8,6"/>
                                </DockPanel>
                                <TextBlock x:Name="ClaudeKeyStatus" Text="" Foreground="{StaticResource Success}" FontSize="11"
                                           FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                <TextBlock Foreground="{StaticResource TextDisabled}" FontSize="11" FontFamily="Segoe UI" Margin="0,8,0,0"
                                           TextWrapping="Wrap">
                                    Get an API key from Anthropic:
                                </TextBlock>
                                <TextBlock Text="https://console.anthropic.com/settings/keys" Foreground="{StaticResource Accent}"
                                           FontSize="11" FontFamily="Consolas" Margin="0,2,0,0"
                                           Cursor="Hand" MouseDown="ClaudeApiLink_Click"
                                           TextDecorations="Underline"/>

                                <Border Height="1" Background="{StaticResource BgElevated}" Margin="0,16"/>

                                <TextBlock Text="Models" Foreground="{StaticResource TextLight}" FontSize="11" FontFamily="Segoe UI"
                                           Margin="0,0,0,6"/>
                                <Button x:Name="RefreshClaudeModelsBtn" Content="Refresh Models from API"
                                        Click="RefreshClaudeModels_Click"
                                        Style="{StaticResource GhostBtn}" Foreground="{StaticResource Accent}"
                                        FontSize="11" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="ClaudeRefreshStatus" Text="" Foreground="{StaticResource TextMuted}" FontSize="11"
                                           FontFamily="Segoe UI" Margin="0,4,0,0" TextWrapping="Wrap"/>

                                <!-- Section Divider -->
                                <Border Height="2" Background="{StaticResource BgElevated}" Margin="0,40,0,40"/>

                                <!-- Gemini Section -->
                                <TextBlock Text="GEMINI IMAGE GENERATION" Foreground="{StaticResource Accent}" FontWeight="Bold"
                                           FontSize="13" FontFamily="Segoe UI" Margin="0,0,0,8"/>
                                <TextBlock Text="Configure Google Gemini API for AI image generation. When Gemini is selected as the model, prompts generate images instead of code."
                                           Foreground="{StaticResource TextSubdued}" FontSize="11" FontFamily="Segoe UI" TextWrapping="Wrap"
                                           Margin="0,0,0,16"/>

                                <TextBlock Text="API Key" Foreground="{StaticResource TextLight}" FontSize="11" FontFamily="Segoe UI"
                                           Margin="0,0,0,6"/>
                                <DockPanel Margin="0,0,0,4">
                                    <Button x:Name="SaveGeminiKeyBtn" Content="Save" Click="SaveGeminiKey_Click"
                                            Style="{StaticResource SmallBtn}" DockPanel.Dock="Right"
                                            Background="{StaticResource Accent}" Padding="10,4" Margin="6,0,0,0"/>
                                    <TextBox x:Name="GeminiApiKeyBox"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             CaretBrush="{StaticResource TextLight}" BorderBrush="{StaticResource BorderSubtle}" BorderThickness="1"
                                             FontSize="11" FontFamily="Consolas" Padding="8,6"/>
                                </DockPanel>
                                <TextBlock x:Name="GeminiKeyStatus" Text="" Foreground="{StaticResource Success}" FontSize="11"
                                           FontFamily="Segoe UI" Margin="0,4,0,0"/>
                                <TextBlock Foreground="{StaticResource TextDisabled}" FontSize="11" FontFamily="Segoe UI" Margin="0,8,0,0"
                                           TextWrapping="Wrap">
                                    Get a free API key from Google AI:
                                    <TextBlock.ToolTip>https://ai.google.dev/gemini-api/docs/api-key</TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Text="https://ai.google.dev/gemini-api/docs/api-key" Foreground="{StaticResource Accent}"
                                           FontSize="11" FontFamily="Consolas" Margin="0,2,0,0"
                                           Cursor="Hand" MouseDown="GeminiApiLink_Click"
                                           TextDecorations="Underline"/>

                                <Border Height="1" Background="{StaticResource BgElevated}" Margin="0,16"/>

                                <TextBlock Text="Model" Foreground="{StaticResource TextLight}" FontSize="11" FontFamily="Segoe UI"
                                           Margin="0,0,0,6"/>
                                <ComboBox x:Name="GeminiModelCombo"
                                          FontSize="11" Padding="6,3" MinWidth="280"
                                          HorizontalAlignment="Left" Margin="0,0,0,4"
                                          SelectionChanged="GeminiModelCombo_Changed"/>
                                <TextBlock Text="Supports native image generation with text prompts. Images are saved to AppData."
                                           Foreground="{StaticResource TextMuted}" FontSize="11" FontFamily="Segoe UI" TextWrapping="Wrap"/>
                                <Button x:Name="RefreshGeminiModelsBtn" Content="Refresh Models from API"
                                        Click="RefreshGeminiModels_Click"
                                        Style="{StaticResource GhostBtn}" Foreground="{StaticResource Accent}"
                                        FontSize="11" HorizontalAlignment="Left" Margin="0,8,0,0"/>
                                <TextBlock x:Name="GeminiRefreshStatus" Text="" Foreground="{StaticResource TextMuted}" FontSize="11"
                                           FontFamily="Segoe UI" Margin="0,4,0,0" TextWrapping="Wrap"/>

                                <Border Height="1" Background="{StaticResource BgElevated}" Margin="0,16"/>

                                <TextBlock Text="Image Storage" Foreground="{StaticResource TextLight}" FontSize="11" FontFamily="Segoe UI"
                                           Margin="0,0,0,6"/>
                                <TextBlock Text="%LOCALAPPDATA%\Spritely\gemini_images\" Foreground="{StaticResource TextSubdued}"
                                           FontSize="11" FontFamily="Consolas" Margin="0,0,0,6"/>
                                <Button x:Name="OpenGeminiImagesBtn" Content="Open Images Folder"
                                        Click="OpenGeminiImages_Click"
                                        Style="{StaticResource GhostBtn}" Foreground="{StaticResource Accent}"
                                        FontSize="11" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <!-- Chat tab -->
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Chat" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                        </TabItem.Header>
                        <DockPanel Margin="4">
                            <!-- Model selector at top -->
                            <DockPanel DockPanel.Dock="Top" Margin="4,4,4,6">
                                <Button x:Name="NewChatBtn" Content="New Chat" Click="NewChat_Click"
                                        Style="{StaticResource GhostBtn}" Foreground="{StaticResource Accent}"
                                        DockPanel.Dock="Right" FontSize="10"/>
                                <TextBlock Text="Model:" Foreground="{StaticResource TextMuted}" FontSize="10"
                                           FontFamily="Segoe UI" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <ComboBox x:Name="ChatModelCombo"
                                          FontSize="10" Padding="4,2" MinWidth="140"
                                          HorizontalAlignment="Left"
                                          SelectionChanged="ChatModelCombo_Changed"/>
                            </DockPanel>
                            <!-- Image preview strip above input -->
                            <WrapPanel x:Name="ChatImagePreview" DockPanel.Dock="Bottom" Margin="0,4,0,0"
                                       Visibility="Collapsed"/>
                            <!-- Input area at the bottom -->
                            <DockPanel DockPanel.Dock="Bottom" Margin="4,6,4,4">
                                <Button x:Name="ChatSendBtn" Content="&#xE724;" Click="ChatSend_Click"
                                        Style="{StaticResource AccentIconBtn}"
                                        DockPanel.Dock="Right" Margin="4,0,0,0" VerticalAlignment="Center"
                                        Padding="6,6" ToolTip="Send message"/>
                                <TextBox x:Name="ChatInput" AcceptsReturn="True" TextWrapping="Wrap"
                                         MaxHeight="60" MinHeight="28"
                                         VerticalScrollBarVisibility="Auto"
                                         AllowDrop="True"
                                         PreviewDragOver="ChatInput_DragOver"
                                         Drop="ChatInput_Drop"
                                         Background="{StaticResource BgDeep}" Foreground="{StaticResource TextPrimary}"
                                         CaretBrush="{StaticResource TextPrimary}" BorderBrush="{StaticResource BorderSubtle}"
                                         BorderThickness="1" FontSize="12" FontFamily="Segoe UI" Padding="6,4"
                                         PreviewKeyDown="ChatInput_PreviewKeyDown"
                                         VerticalContentAlignment="Center"/>
                            </DockPanel>
                            <!-- Chat messages -->
                            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto"
                                            HorizontalScrollBarVisibility="Disabled" Margin="4,0">
                                <StackPanel x:Name="ChatMessagesPanel"/>
                            </ScrollViewer>
                        </DockPanel>
                    </TabItem>
                    <!-- Remote tab -->
                    <TabItem x:Name="RemoteTabItem">
                        <TabItem.Header>
                            <TextBlock Text="Remote" Foreground="{StaticResource TextTabHeader}" FontFamily="Segoe UI" FontSize="11"/>
                        </TabItem.Header>
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                            <StackPanel Margin="12">
                                <!-- Server status indicator -->
                                <Border x:Name="RemoteServerIndicator" CornerRadius="6" Padding="12,10" Margin="0,0,0,12"
                                        Background="{StaticResource BgElevated}" BorderThickness="1" BorderBrush="{StaticResource BgElevated}">
                                    <DockPanel>
                                        <Ellipse x:Name="RemoteServerDot" Width="10" Height="10"
                                                 Fill="#FF5555" DockPanel.Dock="Left" VerticalAlignment="Center"
                                                 Margin="0,0,10,0"/>
                                        <TextBlock x:Name="RemoteServerStatus" Text="Server Stopped"
                                                   Foreground="{StaticResource TextLight}" FontSize="12"
                                                   FontFamily="Segoe UI" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Border>

                                <!-- Server controls -->
                                <TextBlock Text="REST API Server" Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                           FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <TextBlock Text="Enable the REST API so the SpritelyRemote Android app can trigger and monitor tasks over your local network."
                                           Foreground="{StaticResource TextMuted}" FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <DockPanel Margin="0,0,0,8">
                                    <TextBox x:Name="RemoteServerPortBox" Width="70" Text="7923"
                                             FontSize="11"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextLight}"
                                             Padding="6,4" BorderThickness="1"
                                             PreviewTextInput="RemoteServerPortBox_PreviewTextInput"
                                             LostFocus="RemoteServerPortBox_LostFocus"
                                             DockPanel.Dock="Right" Margin="8,0,0,0"/>
                                    <TextBlock Text="Port" Foreground="{StaticResource TextLight}"
                                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"/>
                                </DockPanel>

                                <!-- API Key -->
                                <DockPanel Margin="0,0,0,8">
                                    <Button x:Name="CopyApiKeyBtn" Content="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                            Click="CopyApiKey_Click" ToolTip="Copy API key"
                                            Style="{StaticResource IconBtn}" DockPanel.Dock="Right" Margin="6,0,0,0"
                                            VerticalAlignment="Center"/>
                                    <TextBlock Text="API Key" Foreground="{StaticResource TextLight}"
                                               FontSize="11" FontFamily="Segoe UI" VerticalAlignment="Center"
                                               DockPanel.Dock="Left" Margin="0,0,8,0"/>
                                    <TextBox x:Name="RemoteApiKeyBox" IsReadOnly="True" FontSize="10"
                                             Background="{StaticResource BgDeep}" Foreground="{StaticResource TextMuted}"
                                             Padding="6,4" BorderThickness="1" FontFamily="Consolas"
                                             VerticalAlignment="Center"/>
                                </DockPanel>

                                <WrapPanel Margin="0,0,0,6">
                                    <Button x:Name="RemoteServerStartBtn" Content="&#xE768;  Start Server"
                                            Click="RemoteServerStart_Click"
                                            Style="{StaticResource SecondaryBtn}"
                                            FontSize="11" Padding="12,6"
                                            HorizontalAlignment="Left"/>
                                    <Button x:Name="RemoteServerStopBtn" Content="&#xE71A;  Stop Server"
                                            Click="RemoteServerStop_Click"
                                            Style="{StaticResource SecondaryBtn}"
                                            FontSize="11" Padding="12,6" IsEnabled="False"
                                            HorizontalAlignment="Left" Margin="6,0,0,0"/>
                                </WrapPanel>

                                <!-- Hidden toggle to preserve settings persistence -->
                                <ToggleButton x:Name="RemoteServerToggle" IsChecked="False" Visibility="Collapsed"
                                              Checked="RemoteServerToggle_Changed"
                                              Unchecked="RemoteServerToggle_Changed"/>

                                <!-- Audit Log Badge -->
                                <DockPanel Margin="0,8,0,0">
                                    <TextBlock Text="&#xE7BA;  Audit Log" FontFamily="Segoe MDL2 Assets"
                                               Foreground="{StaticResource TextMuted}" FontSize="11"
                                               VerticalAlignment="Center" DockPanel.Dock="Left" Margin="0,0,8,0"/>
                                    <Border x:Name="AuditLogBadge" Background="{StaticResource BgElevated}"
                                            CornerRadius="8" Padding="6,2" HorizontalAlignment="Left"
                                            VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock x:Name="AuditLogCount" Text="0" FontSize="10"
                                                   Foreground="{StaticResource TextMuted}" FontFamily="Segoe UI"/>
                                    </Border>
                                    <Button x:Name="ViewAuditLogBtn" Content="View Log"
                                            Click="ViewAuditLog_Click"
                                            Style="{StaticResource SecondaryBtn}"
                                            FontSize="10" Padding="8,3"
                                            HorizontalAlignment="Left" VerticalAlignment="Center"/>
                                </DockPanel>

                                <Border Height="1" Background="{StaticResource BgElevated}" Margin="0,14,0,14"/>

                                <!-- APK Build -->
                                <TextBlock Text="Android APK Build" Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                                           FontSize="11" FontFamily="Segoe UI" Margin="0,0,0,4"/>
                                <TextBlock Text="Build the SpritelyRemote Android app. Requires Java/Gradle on PATH."
                                           Foreground="{StaticResource TextMuted}" FontSize="10" FontFamily="Segoe UI" TextWrapping="Wrap" Margin="0,0,0,10"/>

                                <WrapPanel Margin="0,0,0,6">
                                    <Button x:Name="BuildApkDebugBtn" Content="Build Debug APK"
                                            Click="BuildApkDebug_Click"
                                            Style="{StaticResource SecondaryBtn}"
                                            FontSize="11" Padding="10,4"
                                            HorizontalAlignment="Left"/>
                                    <Button x:Name="BuildApkReleaseBtn" Content="Build Release APK"
                                            Click="BuildApkRelease_Click"
                                            Style="{StaticResource SecondaryBtn}"
                                            FontSize="11" Padding="10,4"
                                            HorizontalAlignment="Left" Margin="6,0,0,0"/>
                                </WrapPanel>
                                <TextBlock x:Name="BuildApkStatus" Text=""
                                           Foreground="{StaticResource TextMuted}" FontSize="10" FontFamily="Segoe UI"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>
                </DockPanel>
            </Border>

        <!-- Horizontal Splitter: Output ↔ Terminal -->
        <GridSplitter x:Name="TerminalSplitter" Grid.Row="3" Grid.Column="2" Style="{StaticResource HorizontalSplitter}" Visibility="Collapsed"/>

        <!-- ═══ TERMINAL (6) ═══ -->
        <Border Grid.Row="4" Grid.Column="2" Background="{StaticResource BgSurface}" CornerRadius="8" Padding="4"
                BorderThickness="1" Margin="0,6,0,0">
            <Border.BorderBrush>
                <SolidColorBrush x:Name="TerminalPanelBorder" Color="#2C2C2C"/>
            </Border.BorderBrush>
            <Border.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="TerminalPanelBorder"
                                            Storyboard.TargetProperty="Color"
                                            To="#3A3A3A" Duration="0:0:0.2"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <ColorAnimation Storyboard.TargetName="TerminalPanelBorder"
                                            Storyboard.TargetProperty="Color"
                                            To="#2C2C2C" Duration="0:0:0.3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Border.Triggers>
            <DockPanel>
                <!-- Root path display (very bottom) -->
                <Border x:Name="TerminalRootBar" DockPanel.Dock="Bottom" Background="{StaticResource BgDarkTerminal}" CornerRadius="0,0,6,6" Visibility="Collapsed"
                        Padding="8,3" Margin="0,2,0,0">
                    <TextBlock x:Name="TerminalRootPath"
                               Foreground="{StaticResource TextMuted}" FontFamily="Consolas" FontSize="10"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>
                </Border>
                <DockPanel x:Name="TerminalInputBar" DockPanel.Dock="Bottom" Margin="4,2,4,4" Visibility="Collapsed">
                    <Button x:Name="TerminalInterruptBtn" Content="Ctrl+C" DockPanel.Dock="Right"
                            Style="{StaticResource DangerBtn}"
                            FontWeight="Bold" FontSize="11"
                            Padding="10,4" Margin="4,0,0,0"
                            Click="TerminalInterrupt_Click" ToolTip="Send interrupt (Ctrl+C)"/>
                    <Button x:Name="TerminalSendBtn" Content="Send" DockPanel.Dock="Right"
                            Background="{StaticResource Accent}" Style="{StaticResource SmallBtn}"
                            FontWeight="Bold"
                            Padding="12,4" Margin="4,0,0,0"
                            Click="TerminalSend_Click"/>
                    <TextBox x:Name="TerminalInput"
                             Background="{StaticResource BgTerminalInput}" Foreground="{StaticResource TextBody}" CaretBrush="{StaticResource TextBody}"
                             BorderBrush="{StaticResource BgCard}" BorderThickness="1"
                             FontFamily="Consolas" FontSize="12"
                             Padding="8,4" VerticalContentAlignment="Center"
                             PreviewKeyDown="TerminalInput_PreviewKeyDown"/>
                </DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="8,4,8,2">
                    <Button x:Name="TerminalCollapseBtn" Content="&#xE70E;"
                            Style="{StaticResource IconBtn}" DockPanel.Dock="Left"
                            VerticalAlignment="Center" Margin="0,0,4,0"
                            Click="TerminalCollapse_Click" ToolTip="Expand terminal"/>
                    <TextBlock Text="TERMINAL" Foreground="{StaticResource Accent}" FontWeight="Bold"
                               FontSize="10" FontFamily="Segoe UI" VerticalAlignment="Center"
                               Margin="0,0,8,0" MouseLeftButtonDown="TerminalHeader_MouseDown" Cursor="Hand"/>
                    <StackPanel x:Name="TerminalTabBar" Orientation="Horizontal" VerticalAlignment="Center" Visibility="Collapsed"/>
                </DockPanel>
                <TextBox x:Name="TerminalOutput" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Background="{StaticResource BgAbyss}" Foreground="{StaticResource TextBody}"
                         FontFamily="Consolas" FontSize="12"
                         BorderThickness="0" Padding="8,4" Visibility="Collapsed"
                         PreviewKeyDown="TerminalOutput_PreviewKeyDown"
                         PreviewTextInput="TerminalOutput_PreviewTextInput"/>
            </DockPanel>
        </Border>

        <!-- Loading overlay shown during async startup -->
        <Border x:Name="LoadingOverlay" Grid.RowSpan="5" Grid.ColumnSpan="7"
                Background="{StaticResource BgOverlay}" CornerRadius="8"
                Visibility="Visible" Panel.ZIndex="1000">
            <TextBlock Text="Loading..." Foreground="{StaticResource TextSubdued}"
                       FontSize="16" FontFamily="Segoe UI"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
